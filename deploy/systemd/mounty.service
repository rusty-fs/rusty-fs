[Unit]
Description=Rusty FS mounty FUSE client
After=network-online.target filer.service
Wants=network-online.target

[Service]
Type=simple
# Run mounty as the user that should create and access the FUSE mount.
# Uncomment and adjust these values for your deployment.
# User=era
# Group=era
Environment=RUST_LOG=info
Environment=MOUNTY_CHUNK_SIZE=4194304
Environment=MOUNTY_MAX_BUFFER_SIZE=8388608
# Set these to the UID/GID that should own files in the mounted FUSE view.
# Environment=MOUNTY_UID=1000
# Environment=MOUNTY_GID=1000
ExecStart=/usr/local/bin/mounty http://127.0.0.1:3000 /mnt/rusty-fs
Restart=on-failure
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=30
ExecStopPost=-/bin/fusermount3 -u /mnt/rusty-fs

[Install]
WantedBy=multi-user.target
